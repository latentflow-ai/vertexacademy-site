// Vertex Academy — data model
// Four roles share one User table; profile tables (Faculty/Student) extend it.
// Parents are User rows linked to one or more Students via ParentStudentLink.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum BoardOfEducation {
  CBSE
  SAMACHEER
  ICSE
  JEE
}

enum Stream {
  SCIENCE
  COMMERCE
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  // Public institutional ID (e.g. VA-FAC-0001, VA-25-0001). Used as an
  // alternate login identifier. Null for admins and parents.
  idNumber           String?   @unique
  passwordHash       String
  role               Role
  fullName           String
  phone              String?
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  faculty   Faculty?
  student   Student?
  auditLogs AuditLog[]
}

model Faculty {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId String?  @unique
  subjects   String[] @default([])
  joinedAt   DateTime @default(now())

  assignments      FacultyAssignment[]
  attendanceMarked Attendance[]        @relation("AttendanceMarkedBy")
  marksEntered     Mark[]              @relation("MarkEnteredBy")
  notesUploaded    Note[]              @relation("NoteUploadedBy")
  timetableSlots   TimetableSlot[]
  classTeacherOf   Class[]             @relation("ClassTeacher")
}

model Student {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId       String?
  class         Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
  // Parent/guardian phone, normalized (digits, last 10). Drives parent OTP
  // login: a parent sees every student whose parentPhone matches their number.
  parentPhone   String
  dob           DateTime?
  admissionDate DateTime  @default(now())

  attendance Attendance[]
  marks      Mark[]
  // Subjects this student is enrolled in (a class may offer subjects a given
  // student does not take). Faculty rosters show only enrolled students.
  subjects   Subject[] @relation("StudentSubjects")

  @@index([parentPhone])
}

// One-time password challenge for parent phone login.
model OtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Class {
  id             String           @id @default(cuid())
  name           String
  board          BoardOfEducation
  stream         Stream? // set only for Class 11 & 12
  academicYear   String
  classTeacherId String?
  classTeacher   Faculty?         @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())

  students       Student[]
  subjects       Subject[]
  assignments    FacultyAssignment[]
  attendance     Attendance[]
  timetableSlots TimetableSlot[]
  notes          Note[]
}

model Subject {
  id      String @id @default(cuid())
  name    String
  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  assignments    FacultyAssignment[]
  marks          Mark[]
  attendance     Attendance[]
  timetableSlots TimetableSlot[]
  notes          Note[]
  students       Student[]           @relation("StudentSubjects")

  @@unique([name, classId])
}

model FacultyAssignment {
  id             String   @id @default(cuid())
  facultyId      String
  faculty        Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId      String?
  subject        Subject? @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  isClassTeacher Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([facultyId, classId, subjectId])
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId    String
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus
  markedById String
  markedBy   Faculty          @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([studentId, subjectId, date])
}

model Mark {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  assessment  String
  score       Float
  maxScore    Float    @default(100)
  enteredById String
  enteredBy   Faculty  @relation("MarkEnteredBy", fields: [enteredById], references: [id])
  date        DateTime @default(now())

  @@unique([studentId, subjectId, assessment])
}

model TimetableSlot {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 1=Mon ... 7=Sun
  period    Int
  startTime String
  endTime   String
  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  facultyId String?
  faculty   Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  @@unique([classId, dayOfWeek, period])
}

model Note {
  id           String   @id @default(cuid())
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId    String?
  subject      Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  fileUrl      String
  fileName     String?
  uploadedById String
  uploadedBy   Faculty  @relation("NoteUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

// Atomic sequence source for generating institutional IDs.
model Counter {
  key   String @id
  value Int    @default(0)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
