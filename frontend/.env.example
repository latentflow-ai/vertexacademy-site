# ==========================================
# VERTEX ACADEMY FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local and update values
# ==========================================

# ==================
# Backend API Configuration
# ==================
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ==================
# Application Settings
# ==================
NEXT_PUBLIC_APP_NAME=Vertex Academy
NEXT_PUBLIC_APP_VERSION=1.0.0

# ==================
# Contact Information
# ==================
NEXT_PUBLIC_PHONE=+91-44-XXXX-XXXX
NEXT_PUBLIC_EMAIL=info@vertexacademy.edu.in
NEXT_PUBLIC_ADDRESS=Thiruvanmiyur, Chennai, Tamil Nadu, India

# ==================
# Social Media Links
# ==================
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/vertexacademy
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/vertexacademy
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/vertexacademy
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/vertexacademy
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@vertexacademy

# ==================
# SEO & Meta Tags
# ==================
NEXT_PUBLIC_SITE_TITLE=Vertex Academy - Excellence in Education
NEXT_PUBLIC_SITE_DESCRIPTION=Chennai's leading premium learning destination
NEXT_PUBLIC_SITE_URL=http://localhost:4028
NEXT_PUBLIC_OG_IMAGE=http://localhost:4028/og-image.png

# ==================
# Analytics & Tracking
# ==================
# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==================
# Chat Configuration
# ==================
NEXT_PUBLIC_CHAT_ENABLED=true
NEXT_PUBLIC_CHAT_NAME=Vertex Academy Chat

# ==================
# Feature Flags
# ==================
NEXT_PUBLIC_ENABLE_GALLERY=true
NEXT_PUBLIC_ENABLE_CAMPUS_VISIT=true
NEXT_PUBLIC_ENABLE_ENROLLMENT=true
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=true

# ==================
# Appearance & UI
# ==================
NEXT_PUBLIC_THEME=dark
NEXT_PUBLIC_PRIMARY_COLOR=#3B82F6
NEXT_PUBLIC_SECONDARY_COLOR=#10B981

# ==================
# Performance
# ==================
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# ==================
# Development/Debug
# ==================
NEXT_PUBLIC_DEBUG_MODE=false
